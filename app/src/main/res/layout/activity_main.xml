<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    style="@style/MainActivityStyle">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/main_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:title="@string/app_name"
        style="@style/ToolbarStyle"
        app:titleTextColor="@color/white"/>

    <Button
        android:id="@+id/main_button_search"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/various_elements_layout_marginHorizontal"
        android:layout_marginBottom="16dp"
        android:text="@string/search"
        app:icon="@drawable/ic_search"
        app:iconPadding="@dimen/main_btn_iconPadding"
        app:iconGravity="textStart"
        style="@style/MainButtonsStyle"/>

    <Button
        android:id="@+id/main_button_library"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/various_elements_layout_marginHorizontal"
        android:layout_marginBottom="16dp"
        android:text="@string/library"
        app:icon="@drawable/ic_library"
        app:iconPadding="@dimen/main_btn_iconPadding"
        app:iconGravity="textStart"
        style="@style/MainButtonsStyle"/>

    <Button
        android:id="@+id/main_button_settings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/various_elements_layout_marginHorizontal"
        android:layout_marginBottom="28dp"
        android:text="@string/settings"
        app:icon="@drawable/ic_settings"
        app:iconPadding="@dimen/main_btn_iconPadding"
        app:iconGravity="textStart"
        style="@style/MainButtonsStyle"/>
</LinearLayout>