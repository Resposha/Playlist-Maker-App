<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/search_toolbar"
        app:title="@string/search"
        style="@style/ToolbarStyle"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/search_field_layout_height"
        android:layout_marginHorizontal="@dimen/various_elements_layout_marginHorizontal"
        android:layout_marginVertical="@dimen/search_field_layout_marginVertical">

        <EditText
            android:id="@+id/search_edit_text"
            android:layout_gravity="center"
            android:background="@drawable/search_bar_background"
            android:inputType="text"
            android:hint="@string/search"
            android:maxLines="1"
            android:drawableStart="@drawable/ic_search_small"
            style="@style/SearchEditTextStyle"/>

        <ImageView
            android:id="@+id/search_icon_clear"
            android:src="@drawable/ic_clear"
            android:visibility="gone"
            style="@style/SearchIconClearStyle"/>
    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/search_track_recyclerview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/search_recyclerview_layout_marginTop"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
</LinearLayout>