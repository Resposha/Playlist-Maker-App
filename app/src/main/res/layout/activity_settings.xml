<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingEnd="12dp">
    
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/settings_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:title="@string/settings"
        app:titleTextColor="@color/black"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <Switch
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:paddingStart="@dimen/settings_paddingStart"
        android:gravity="center|start"
        android:text="@string/dark_theme"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        android:checked="true" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:paddingStart="@dimen/settings_paddingStart"
        android:text="@string/share_app"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        app:drawableEndCompat="@drawable/ic_share" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:paddingStart="@dimen/settings_paddingStart"
        android:text="@string/contact_support"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        app:drawableEndCompat="@drawable/ic_support" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:paddingStart="@dimen/settings_paddingStart"
        android:text="@string/user_agreement"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        app:drawableEndCompat="@drawable/ic_arrow_forward" />
</LinearLayout>