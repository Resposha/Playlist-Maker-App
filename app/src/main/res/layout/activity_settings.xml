<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingStart="16dp"
    android:paddingEnd="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="40dp"
        android:text="@string/settings"
        android:textColor="@color/black"
        android:textSize="22sp"
        app:drawableStartCompat="@drawable/ic_arrow_back"
        android:drawablePadding="24dp" />

    <Switch
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:gravity="start"
        android:text="@string/dark_theme"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        android:checked="true" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:text="@string/share_app"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        app:drawableEndCompat="@drawable/ic_share" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:text="@string/contact_support"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        app:drawableEndCompat="@drawable/ic_support" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/settings_layout_marginTop_and_marginBottom"
        android:layout_marginBottom="@dimen/settings_layout_marginTop_and_marginBottom"
        android:text="@string/user_agreement"
        android:textColor="@color/black"
        android:textSize="@dimen/settings_textSize"
        app:drawableEndCompat="@drawable/ic_arrow_forward" />
</LinearLayout>