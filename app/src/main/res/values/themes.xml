<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PlaylistMaker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>
    <style name="MainActivityStyle">
        <item name="android:background">@color/blue</item>
    </style>
    <style name="SettingsActivityStyle">
        <item name="android:background">@color/white</item>
    </style>
    <style name="ToolbarStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/toolbar_textSize</item>
        <item name="titleTextColor">@color/black</item>
        <item name="navigationIconTint">@color/black</item>
    </style>
    <style name="MainButtonsStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/main_textSize</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="iconTint">@color/black</item>
        <item name="cornerRadius">@dimen/main_Button_cornerRadius</item>
    </style>
    <style name="SettingsSwitchAndTextViewsStyle">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/settings_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="drawableTint">@color/text_gray</item>
    </style>
    <style name="SearchEditTextStyle">
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/text_gray</item>
        <item name="android:textSize">@dimen/search_EditText_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:backgroundTint">@color/light_gray</item>
        <item name="drawableTint">@color/text_gray</item>
    </style>
    <style name="SearchIconClearStyle">
        <item name="tint">@color/text_gray</item>
    </style>
    <style name="SearchTrackNameStyle">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/search_track_name_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
    </style>
    <style name="SearchArtistNameAndTrackTimeStyle">
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textSize">@dimen/search_artist_name_and_track_time_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="tint">@color/text_gray</item>
    </style>
    <style name="SearchImageViewArrowForwardStyle">
        <item name="tint">@color/text_gray</item>
    </style>
    <style name="SearchPlaceholderTextViewStyle">
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/search_placeholder_TextView_textSize</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">400</item>
    </style>
    <style name="SearchPlaceholderReloadButtonStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/search_placeholder_Button_textSize</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:backgroundTint">@color/black</item>
        <item name="cornerRadius">@dimen/search_placeholder_Button_cornerRadius</item>
    </style>
</resources>