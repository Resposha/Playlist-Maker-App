<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PlaylistMaker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->
    </style>
    <style name="MainActivityStyle">
        <item name="android:background">@color/black</item>
    </style>
    <style name="SettingsActivityStyle">
        <item name="android:background">@color/black</item>
    </style>
    <style name="ToolbarStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/toolbar_textSize</item>
        <item name="titleTextColor">@color/white</item>
        <item name="navigationIconTint">@color/white</item>
    </style>
    <style name="MainButtonsStyle" parent="Widget.MaterialComponents.Button.UnelevatedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/main_btn_layout_height</item>
        <item name="android:layout_marginHorizontal">@dimen/various_elements_layout_marginHorizontal</item>
        <item name="android:layout_weight">@dimen/main_btn_layout_weight</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/main_textSize</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/main_btn_iconPadding</item>
        <item name="iconTint">@color/black</item>
        <item name="cornerRadius">@dimen/main_btn_cornerRadius</item>
    </style>
    <style name="SettingsSwitchAndTextViewsStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/settings_layout_marginTop_and_marginBottom</item>
        <item name="android:layout_marginBottom">@dimen/settings_layout_marginTop_and_marginBottom</item>
        <item name="android:paddingStart">@dimen/settings_paddingStart</item>
        <item name="android:paddingEnd">@dimen/settings_paddingEnd</item>
        <item name="android:gravity">center|start</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/settings_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:thumbTint">@color/blue</item>
        <item name="android:trackTint">@color/blue_light</item>
        <item name="drawableTint">@color/white</item>
    </style>
    <style name="SearchEditTextStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:paddingStart">@dimen/search_EditText_paddingStart</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/black</item>
        <item name="android:textSize">@dimen/search_EditText_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="drawableTint">@color/black</item>
    </style>
    <style name="SearchIconClearStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center|end</item>
        <item name="android:paddingEnd">@dimen/search_ImageView_paddingEnd</item>
        <item name="tint">@color/black</item>
    </style>
    <style name="SearchTrackNameStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/search_track_name_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
    </style>
    <style name="SearchArtistNameAndTrackTimeStyle">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/search_artist_name_and_track_time_textSize</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
        <item name="tint">@color/white</item>
    </style>
    <style name="SearchImageViewArrowForwardStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="tint">@color/white</item>
    </style>
</resources>